# OpenAI API key (same as gestionale, can be shared)
OPENAI_API_KEY=sk-...

# Absolute path to the salnegra static site repo on the server
SITE_ROOT=/root/salnegra-site

# Git settings (used to push after generation)
GIT_AUTHOR_NAME=Sal Negra Blog Bot
GIT_AUTHOR_EMAIL=blog-bot@salnegratenerife.com
GIT_BRANCH=main

# Optional: skip git push (for testing)
# DRY_RUN=1

# Optional: pin topic id (otherwise auto-picks next unpublished)
# TOPIC_ID=5
